{
    "name": "example/zephyrus-hello",
    "description": "Minimal Zephyrus example for the agentskills.io zephyrus skill.",
    "type": "project",
    "license": "MIT",
    "minimum-stability": "dev",
    "prefer-stable": true,
    "repositories": [
        {
            "type": "vcs",
            "url": "https://github.com/zephyrus-framework/core.git"
        }
    ],
    "require": {
        "php": "^8.4",
        "ext-intl": "*",
        "ext-mbstring": "*",
        "ext-pdo": "*",
        "ext-sodium": "*",
        "zephyrus-framework/core": "dev-dev"
    },
    "autoload": {
        "psr-4": {
            "App\\Controllers\\": "app/Controllers",
            "App\\Models\\": "app/Models"
        }
    },
    "config": {
        "sort-packages": true
    }
}
